        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-neutral-950 w-full py-12 md:py-16 border-t border-neutral-900/80 relative overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full md:w-[800px] h-px bg-gradient-to-r from-transparent via-red-600/50 to-transparent"></div>
        <div class="flex flex-col items-center gap-4 md:gap-6 w-full px-8 relative z-10">
            <div class="text-xl md:text-2xl font-black text-red-600 tracking-tighter hover:scale-110 transition-transform cursor-pointer">IT.</div>
            <p class="font-mono text-[10px] md:text-xs uppercase tracking-[0.2em] text-neutral-500">© 2026 IT. All rights reserved.</p>
            <div class="flex gap-6 md:gap-8 mt-2 md:mt-4">
                <a class="font-mono text-[10px] md:text-xs uppercase tracking-[0.1em] text-neutral-500 hover:text-red-500 transition-colors" href="#">Privacy Policy</a>
                <a class="font-mono text-[10px] md:text-xs uppercase tracking-[0.1em] text-neutral-500 hover:text-red-500 transition-colors" href="#">Terms of Service</a>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <!-- AOS Animation Engine -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Init AOS Animations
        AOS.init({
            duration: 800,
            once: true,
            offset: 50,
            easing: 'ease-out-cubic',
        });

        // Navbar Scroll Effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                navbar.classList.add('shadow-xl', 'shadow-black/50', 'bg-neutral-950/90');
                navbar.classList.remove('bg-neutral-950/80', 'py-4', 'md:py-6');
                navbar.classList.add('py-3', 'md:py-4');
            } else {
                navbar.classList.remove('shadow-xl', 'shadow-black/50', 'bg-neutral-950/90', 'py-3', 'md:py-4');
                navbar.classList.add('bg-neutral-950/80', 'py-4', 'md:py-6');
            }
        });
    </script>
</body>
</html>
